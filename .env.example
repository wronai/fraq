# fraq — text2fraq configuration
# Copy to .env and fill with your values

# ═══════════════════════════════════════════════════════════════════════════
# LiteLLM Configuration
# ═══════════════════════════════════════════════════════════════════════════

# API provider: openai, ollama, anthropic, cohere, etc.
LITELLM_PROVIDER=ollama

# Model name (supports small models like qwen2.5:3b, llama3.2:3b, phi3:3.8b)
LITELLM_MODEL=qwen2.5:3b

# API key (if needed, e.g., for OpenAI, Anthropic)
# Leave empty for local models via Ollama
LITELLM_API_KEY=

# Base URL for API (e.g., for Ollama: http://localhost:11434, for OpenRouter)
LITELLM_BASE_URL=http://localhost:11434

# Temperature for generation (0.0 - 1.0, lower = more deterministic)
LITELLM_TEMPERATURE=0.1

# Max tokens per request
LITELLM_MAX_TOKENS=512

# Timeout in seconds
LITELLM_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════════════════
# text2fraq Settings
# ═══════════════════════════════════════════════════════════════════════════

# Default output format: json, csv, yaml, jsonl
TEXT2FRAQ_DEFAULT_FORMAT=json

# Default dimensions for fractal (2-10)
TEXT2FRAQ_DEFAULT_DIMS=3

# Default depth for queries (1-20)
TEXT2FRAQ_DEFAULT_DEPTH=3

# Enable caching of parsed queries
TEXT2FRAQ_CACHE_ENABLED=true

# Cache TTL in seconds (3600 = 1 hour)
TEXT2FRAQ_CACHE_TTL=3600

# ═══════════════════════════════════════════════════════════════════════════
# Application Examples Configuration
# ═══════════════════════════════════════════════════════════════════════════

# IoT/Sensor simulation settings
SENSOR_BASE_TEMP=23.5
SENSOR_BASE_HUMIDITY=60.0
SENSOR_SAMPLE_HZ=10

# Database connection (for SQL adapter examples)
# Example: postgresql://user:pass@localhost/fraq or sqlite:///fraq.db
DATABASE_URL=sqlite:///fraq_examples.db

# HTTP API base URL (for HTTP adapter examples)
HTTP_API_BASE_URL=https://api.example.com

# Enable/disable specific examples
ENABLE_IOT_EXAMPLES=true
ENABLE_ERP_EXAMPLES=true
ENABLE_FINANCE_EXAMPLES=true
ENABLE_LEGAL_EXAMPLES=true
ENABLE_AI_ML_EXAMPLES=true
ENABLE_DEVOPS_EXAMPLES=true
